<% const _src = srcPath; const _public = publicPath; %>
<!-- prettier-ignore -->
<%
  const _href = typeof href !== 'undefined' ? href : '#!';
  const _name = typeof name !== 'undefined' ? name : '';
  const _value = typeof value !== 'undefined' ? value : '';
  const _title = typeof title !== 'undefined' ? title : '';
  const _count = typeof count !== 'undefined' ? Number(count) : 0;
  const _desc = typeof desc !== 'undefined' ? desc : '';
  const _date = typeof date !== 'undefined' ? date : '';
  const _checked = typeof checked !== 'undefined' ? checked : false;
  const _disabled = typeof disabled !== 'undefined' ? disabled : false;

  // D] 타이틀/설명 최대 30자까지만 출력
  const _displayTitle = _title.length > 30 ? _title.slice(0, 30) : _title;
  const _displayDesc = _desc.length > 30 ? _desc.slice(0, 30) : _desc;

  // [D] 화면 산출물용 폴더 개수 표시 (100 초과, +100)
  const _displayCount = _count > 100 ? '+100' : _count;
%>
<div class="vits-favorites-folder-grid">
  <!-- prettier-ignore -->
  <%- include(`${_src}/views/components/form/checkbox-item.ejs`, {
    name: _name,
    value: _value,
    checkboxType: "item",
    checked: _checked,
    disabled: _disabled,
    size: 'xl'
  }) %>

  <a href="<%= _href %>" class="folder-link">
    <div class="folder-content">
      <p class="content-title">
        <span class="title-name"><%= _displayTitle %></span>
        <span class="title-count"><%= _displayCount %>개</span>
      </p>
      <% if (_displayDesc) { %>
      <p class="content-desc"><%= _displayDesc %></p>
      <% } %>
    </div>
    <p class="folder-date"><%= _date %></p>
  </a>
</div>
