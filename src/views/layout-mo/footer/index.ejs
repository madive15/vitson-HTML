              </tr>
              <tr>
                <th scope="row">신고기관</th>
                <td data-biz-field="dclrInsttNm">-</td>
              </tr>
              <tr>
                <th scope="row">신고일자</th>
                <td data-biz-field="fromYmd">-</td>
              </tr>
              <tr>
                <th scope="row">인허가(등록)번호</th>
                <td data-biz-field="prmmiMnno">-</td>
              </tr>
            </tbody>
          </table>

          <p class="vm-footer-modal-note">표시 정보는 OpenAPI 조회 결과 기준입니다.</p>
        </div>
      </div>
    </div>
  </section>
</footer>
