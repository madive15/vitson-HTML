<% const _src = srcPath; const _public = publicPath; %>

<!-- prettier-ignore -->
<% var _value = typeof value !== 'undefined' ? value : ''; %>

<!-- prettier-ignore -->
<% if (type === 'main-bar') { %>
  <%- include('./main-bar.ejs', { ...locals }) %>
<% } else if (type === 'nav-bar') { %>
  <%- include('./nav-bar.ejs', { title: title }) %>
<% } else if (type === 'nav-bar-step') { %>
  <%- include('./nav-bar-step.ejs') %>
<% } else if (type === 'product-bar') { %>
  <%- include('./product-bar.ejs') %>
<% } else if (type === 'nav-bar-logo') { %>
  <%- include('./nav-bar-logo.ejs') %>
<% } else if (type === 'search-bar') { %>
  <%- include('./search-bar.ejs', { value: _value }) %>
<% } %>
