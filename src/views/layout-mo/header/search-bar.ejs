<% const _src = srcPath; const _public = publicPath; %>
<!-- prettier-ignore -->

<header class="vm-header header-search-bar">
  <a href="#!" class="vm-header-back" aria-label="이전 페이지">
    <!-- prettier-ignore -->
    <%- include(`${_src}/views/components/icon.ejs`, {
      iconName: 'arrow-left' 
    }) %>
  </a>
  
  <div class="vm-header-search">
    <!-- prettier-ignore -->
    <%- include(`${_src}/views/components/form/input-search.ejs`, {
      idPrefix: 'search',
      action: '/search',
      name: 'keyword',
      placeholder: '찾고싶은 상품을 검색해보세요.',
      addDataInput: 'search-input',  
      addBtnText: '검색',
      hasClear: true
    }) %>

    <button type="button" class="vm-header-btn btn-mic" aria-label="음성 검색">
      <%- include(`${_src}/views/components/icon.ejs`, { iconName: "mic" }) %>
    </button>
  </div>
   <div class="vm-header-actions">
    <button type="button" class="vm-header-btn btn-cart" aria-label="장바구니">
      <%- include(`${_src}/views/components/icon.ejs`, { iconName: "bag" }) %>
      <span class="badge">99+</span>
    </button>
  </div>
</header>
