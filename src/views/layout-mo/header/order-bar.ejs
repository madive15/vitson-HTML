<% const _src = srcPath; const _public = publicPath; %>
<!-- prettier-ignore -->
<% 
  const _title = (typeof title !== 'undefined' && title) ? title : '주문/결제'; 
  const _hasActions = typeof hasActions !== 'undefined' ? hasActions : true;
%>

<header class="vm-header header-order-bar">
  <!-- prettier-ignore -->
  <%- include('./header-button.ejs', { 
    button: 'back' })
  %>

  <p class="vm-header-title" data-header-title><%= _title %></p>

  <% if (_hasActions) { %>
  <div class="vm-header-actions">
    <!-- prettier-ignore -->
    <%- include('./header-button.ejs', { 
      button: 'search' })
    %>
  </div>
  <% } %>
</header>
