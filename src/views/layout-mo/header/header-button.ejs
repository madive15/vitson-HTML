<% const _src = srcPath; const _public = publicPath; %>
<!-- prettier-ignore -->

<!-- 
  back:   { label: '뒤로가기', icon: 'arrow-left', badge: false },
  close:  { label: '닫기', icon: 'close',      badge: false },
  share:  { label: '공유', icon: 'share',      badge: false },
  like:   { label: '좋아요',   icon: 'heart',      badge: false },
  alarm:  { label: '알림',     icon: 'bell',       badge: 'dot',   href: '/alarm' },
  search: { label: '검색',     icon: 'search',     badge: false,   href: '/search' }
-->

<%
  // 버튼 정의 맵
  // tag: 생략 시 href 유무로 자동 결정 (href 있으면 a, 없으면 button)
  // badge: 'count' (숫자) | 'dot' (점) | false (없음)
  var btnMap = {  
    cart: { label: '장바구니', icon: 'cart', badge: 'count', href: '/cart' },
    alarm: { label: '알림', icon: 'bell', badge: 'dot', href: '/alarm' }
  };

  var btn = btnMap[button];
  var btnHref = (typeof href !== 'undefined') ? href : (btn.href || '');
  var tag = btnHref ? 'a' : 'button';
%>

<% if (btn) { %>
  <<%= tag %>
    <% if (tag === 'a') { %>href="<%= btnHref %>"<% } %>
    <% if (tag === 'button') { %>type="button"<% } %>
    class="vm-header-btn btn-<%= button %>"
    aria-label="<%= btn.label %>"
  >
    <%- include(`${_src}/views/components/icon.ejs`, { iconName: btn.icon }) %>
    <% if (btn.badge === 'count') { %>
      <% var badgeCount = parseInt((typeof count !== 'undefined') ? count : 0, 10); %>
      <% if (badgeCount > 0) { %>
        <% var display = badgeCount > 99 ? '99+' : String(badgeCount); %>
        <span class="badge count" data-header-badge="count" aria-hidden="true"><span class="num"><%= display %></span></span>
      <% } %>
    <% } else if (btn.badge === 'dot') { %>
      <% var hasAlarm = (typeof alarm !== 'undefined') ? alarm : false; %>
      <% if (hasAlarm) { %>
        <span class="badge dot" data-header-badge="dot" aria-label="새 알림 있음"></span>
      <% } %>
    <% } %>
  </<%= tag %>>
<% } %>