<% const _src = srcPath; const _public = publicPath; %>
<!-- prettier-ignore -->

<%
const _homeData = require(`${_src}/../public/resources/mock/home-data.js`);
const _slides = _homeData.slides;
const _menus = _homeData.menus;
const _categoryMenus = _homeData.categoryMenus;
const _promoBanner = _homeData.promoBanner;

const _dealProducts = _homeData.getDealProducts(_public);
const _frequentProducts = _homeData.getFrequentProducts();
const _legendProducts = _homeData.getLegendProducts();
const _popularCategories = _homeData.getPopularCategories();
const _categoryBestProducts = _homeData.getCategoryBestProducts();
%>

<!DOCTYPE html>
<html lang="ko" class="vm-scope">
  <%- include(`${_src}/views/layout-mo/header/head.ejs`, {meta_title: '메인'}) %>
  <body class="vm-scope">
    <!-- S: Skip Navigation -->
    <a href="#skipNav" class="skip-nav">본문 바로가기</a>
    <!-- E: Skip Navigation -->

    <!-- S: vm-wrapper -->
    <section class="vm-wrapper">
      <!-- S: vm-wrap -->
      <div class="vm-wrap wrap-home">
        <!-- S: vm-content-wrap -->
        <div class="vm-content-wrap">
          <!-- prettier-ignore -->
          <%- include(`${_src}/views/layout-mo/header/index.ejs`, { 
            type: 'main-bar',
            alarm: true,
            count: 100
          }) %>

          <!-- S: vm-main -->
          <main id="skipNav" class="vm-main">
            <div class="vm-main-content main-content-home">
              <section class="vm-home-section">
                <h2 class="sr-only">비츠온앰알오 모바일 메인</h2>

                <!-- 비쥬얼 배너 -->
                <!-- prettier-ignore -->
                <%- include(`${_src}/views/components-mo/home/home-visual.ejs`, {
                  slides: _slides
                }) %>

                <!-- 자주 찾는 메뉴 바로가기 -->
                <!-- prettier-ignore -->
                <%- include(`${_src}/views/components-mo/home/home-frequent-menu.ejs`, {
                  menus: _menus
                }) %>

                <!-- 초특가 제안 -->
                <!-- prettier-ignore -->
                <%- include(`${_src}/views/components-mo/home/home-recommend.ejs`, {
                  type: 'deal',
                  products: _dealProducts,
                  href: '#!',
                  title: '비츠온만의 <span class="point-color">초특가 제안</span>' }) %>

                <!-- 카테고리 바로가기  -->
                <!-- prettier-ignore -->
                <%- include(`${_src}/views/components-mo/home/home-category-menu.ejs`, {
                  categoryMenus: _categoryMenus
                }) %>

                <!-- 자주 구매한 상품 & 많이 찾는 카테고리 -->
                <div class="vm-home-popular">
                  <!-- 
                    [D] 자주 구매한 상품
                         ㄴ 사용자 데이터에 따라 노출? 미노출 
                  -->
                  <!-- prettier-ignore -->
                  <%- include(`${_src}/views/components-mo/home/home-recommend.ejs`, {
                    type: 'frequent',
                    products: _frequentProducts,
                    href: '#!',
                    title: '고객님께서 <span class="point-color">자주 구매한 상품</span>' }) %>

                  <!-- 많이 찾는 카테고리  -->
                  <!-- prettier-ignore -->
                  <%- include(`${_src}/views/components-mo/home/home-banner-tab.ejs`, {
                    numbered: true,
                    tabs: _popularCategories,
                    speed: 2000,
                    menuSpaceBetween: 8,
                    contentSpaceBetween: 16,
                    title: '지금 많이 찾으시는 <span class="point-color">카테고리</span>' }) %>
                </div>

                <!-- 카테고리 BEST -->
                <!-- prettier-ignore -->
                <%- include(`${_src}/views/components-mo/home/home-banner-tab-hscroll.ejs`, {
                ranked: true,
                tabs: _categoryBestProducts,
                href: "#!",
                menuSpaceBetween: 8,
                contentSpaceBetween: 16,
                title: '카테고리 <span class="point-color">BEST</span>' }) %>

                <!-- 기획전 배너 -->
                <!-- prettier-ignore -->
                <%- include(`${_src}/views/components-mo/home/home-promo-banner.ejs`, {
                  href: _promoBanner.href,
                  imageSrc: `${_promoBanner.img}`,
                  alt: _promoBanner.alt 
                }) %>

                <!-- 레전드 -->
                <!-- prettier-ignore -->
                <%- include(`${_src}/views/components-mo/home/home-recommend.ejs`, {
                  type: 'legend',
                  products: _legendProducts,
                  title: '비츠온 <span class="point-color">레전드</span>' }) %>
              </section>

              <!-- S: peek형 배너 (1.2) -->
              <section
                data-ui="banner-peek"
                data-slides-per-view="1.2"
                data-space-between="12"
                style="padding: 0 0 0 16px; margin-bottom: 40px"
              >
                <div class="swiper">
                  <div class="swiper-wrapper">
                    <div
                      class="swiper-slide"
                      style="
                        height: 180px;
                        border-radius: 12px;
                        display: flex;
                        align-items: center;
                        justify-content: center;
                        font-size: 18px;
                        font-weight: 700;
                        color: #fff;
                        background: #e67e22;
                      "
                    >
                      <a href="#!">peek 1</a>
                    </div>
                    <div
                      class="swiper-slide"
                      style="
                        height: 180px;
                        border-radius: 12px;
                        display: flex;
                        align-items: center;
                        justify-content: center;
                        font-size: 18px;
                        font-weight: 700;
                        color: #fff;
                        background: #16a085;
                      "
                    >
                      <a href="#!">peek 2</a>
                    </div>
                    <div
                      class="swiper-slide"
                      style="
                        height: 180px;
                        border-radius: 12px;
                        display: flex;
                        align-items: center;
                        justify-content: center;
                        font-size: 18px;
                        font-weight: 700;
                        color: #fff;
                        background: #8e44ad;
                      "
                    >
                      <a href="#!">peek 3</a>
                    </div>
                    <div
                      class="swiper-slide"
                      style="
                        height: 180px;
                        border-radius: 12px;
                        display: flex;
                        align-items: center;
                        justify-content: center;
                        font-size: 18px;
                        font-weight: 700;
                        color: #fff;
                        background: #2c3e50;
                      "
                    >
                      <a href="#!">peek 4</a>
                    </div>
                  </div>
                </div>
              </section>
              <!-- E: peek형 배너 (1.2) -->

              <!-- S: peek형 배너 (1.4) -->
              <section
                data-ui="banner-peek"
                data-slides-per-view="1.4"
                data-space-between="16"
                style="padding: 0 0 0 16px; margin-bottom: 40px"
              >
                <div class="swiper">
                  <div class="swiper-wrapper">
                    <div
                      class="swiper-slide"
                      style="
                        height: 180px;
                        border-radius: 12px;
                        display: flex;
                        align-items: center;
                        justify-content: center;
                        font-size: 18px;
                        font-weight: 700;
                        color: #fff;
                        background: #1abc9c;
                      "
                    >
                      <a href="#!">peek A</a>
                    </div>
                    <div
                      class="swiper-slide"
                      style="
                        height: 180px;
                        border-radius: 12px;
                        display: flex;
                        align-items: center;
                        justify-content: center;
                        font-size: 18px;
                        font-weight: 700;
                        color: #fff;
                        background: #e74c3c;
                      "
                    >
                      <a href="#!">peek B</a>
                    </div>
                    <div
                      class="swiper-slide"
                      style="
                        height: 180px;
                        border-radius: 12px;
                        display: flex;
                        align-items: center;
                        justify-content: center;
                        font-size: 18px;
                        font-weight: 700;
                        color: #fff;
                        background: #3498db;
                      "
                    >
                      <a href="#!">peek C</a>
                    </div>
                  </div>
                </div>
              </section>
              <!-- E: peek형 배너 (1.4) -->
            </div>
          </main>
          <!-- E: vm-main -->

          <%- include(`${_src}/views/layout-mo/footer/index.ejs`, { showFooter: true }) %>
        </div>
        <!-- E: vm-content-wrap -->

        <!-- S: vm-bottom-group -->
        <!-- prettier-ignore -->
        <%- include(`${_src}/views/layout-mo/bottom-bar/index.ejs`, { 
          type: 'tab-bar', currentTab: 'home' 
        }) %>
        <!-- E: vm-bottom-group -->

        <!-- S: 팝업 영역 -->
        <!-- E: 팝업 영역 -->
      </div>
      <!-- E: vm-wrap -->
    </section>
    <!-- E: vm-wrapper -->

    <%- include(`${_src}/views/layout/footer.links.ejs`) %>
  </body>
</html>
