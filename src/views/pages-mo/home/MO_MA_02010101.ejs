<% const _src = srcPath; const _public = publicPath; %>
<!-- prettier-ignore -->

<%
const _homeData = require(`${_src}/../public/resources/mock/home-data.js`);
const _slides = _homeData.slides;

const _menus = _homeData.menus;
const _categoryMenus = _homeData.categoryMenus;

const _promoBanner = _homeData.promoBanner;
const _peekBanners = _homeData.peekBanners;

const _dealProducts = _homeData.getDealProducts(_public);
const _frequentProducts = _homeData.getFrequentProducts();
const _legendProducts = _homeData.getLegendProducts();
const _popularCategories = _homeData.getPopularCategories();
const _categoryBestProducts = _homeData.getCategoryBestProducts();
const _flashDealProducts = _homeData.getFlashDealProducts(_public);

const _brandExhibition = _homeData.brandExhibition;
%>

<!DOCTYPE html>
<html lang="ko" class="vm-scope">
  <%- include(`${_src}/views/layout-mo/header/head.ejs`, {meta_title: '메인'}) %>
  <body class="vm-scope">
    <!-- S: Skip Navigation -->
    <a href="#skipNav" class="skip-nav">본문 바로가기</a>
    <!-- E: Skip Navigation -->

    <!-- S: vm-wrapper -->
    <section class="vm-wrapper">
      <!-- S: vm-wrap -->
      <div class="vm-wrap wrap-home">
        <!-- S: vm-content-wrap -->
        <div class="vm-content-wrap">
          <!-- prettier-ignore -->
          <%- include(`${_src}/views/layout-mo/header/index.ejs`, { 
            type: 'main-bar',
            alarm: true,
            count: 100
          }) %>

          <!-- S: vm-main -->
          <main id="skipNav" class="vm-main">
            <div class="vm-main-content main-content-home">
              <section class="vm-home-section">
                <h2 class="sr-only">비츠온앰알오 모바일 메인</h2>

                <!-- 비쥬얼 배너 -->
                <!-- prettier-ignore -->
                <%- include(`${_src}/views/components-mo/home/home-visual.ejs`, {
                  slides: _slides
                }) %>

                <!-- 자주 찾는 메뉴 바로가기 -->
                <!-- prettier-ignore -->
                <%- include(`${_src}/views/components-mo/home/home-frequent-menu.ejs`, {
                  menus: _menus
                }) %>

                <!-- 초특가 제안 -->
                <!-- prettier-ignore -->
                <%- include(`${_src}/views/components-mo/home/home-recommend.ejs`, {
                  type: 'deal',
                  products: _dealProducts,
                  href: '#!',
                  memberYn: 'N',
                  title: '비츠온만의 <span class="point-color">초특가 제안</span>' }) %>

                <!-- 카테고리 바로가기  -->
                <!-- prettier-ignore -->
                <%- include(`${_src}/views/components-mo/home/home-category-menu.ejs`, {
                  categoryMenus: _categoryMenus
                }) %>

                <!-- 오늘의 행사  -->
                <!-- prettier-ignore -->
                <%- include(`${_src}/views/components-mo/home/home-swiper-peek-banner.ejs`, {
                  banners: _peekBanners,
                  title: '<span class="point-color">오늘의 행사</span> 놓치지 마세요' }) %>

                <!-- 카테고리 BEST -->
                <!-- prettier-ignore -->
                <%- include(`${_src}/views/components-mo/home/home-banner-tab-hscroll.ejs`, {
                ranked: true,
                tabs: _categoryBestProducts,
                href: "#!",
                menuSpaceBetween: 8,
                contentSpaceBetween: 16,
                memberYn: 'N',
                title: '카테고리 <span class="point-color">BEST</span>' }) %>

                <!-- 기획전 배너 -->
                <!-- prettier-ignore -->
                <%- include(`${_src}/views/components-mo/home/home-promo-banner.ejs`, {
                  href: _promoBanner.href,
                  imageSrc: `${_promoBanner.img}`,
                  alt: _promoBanner.alt 
                }) %>

                <!-- 레전드 -->
                <!-- prettier-ignore -->
                <%- include(`${_src}/views/components-mo/home/home-recommend.ejs`, {
                  type: 'legend',
                  products: _legendProducts,
                  memberYn: 'N',
                  title: '비츠온 <span class="point-color">레전드</span>' }) %>

                <!-- 브랜드 기획전 -->
                <!-- prettier-ignore -->
                <%- include(`${_src}/views/components-mo/home/home-promo-brand.ejs`, {
                  href: "#!",
                  banners: _brandExhibition.banners,
                  brands: _brandExhibition.brands,
                  memberYn: 'N',
                  title: '비츠온 <span class="point-color">Pick 브랜드</span>' }) %>

                <!-- 반짝특가 -->
                <!-- prettier-ignore -->
                <%- include(`${_src}/views/components-mo/home/home-banner-tab-hscroll.ejs`, {
                tabs: _flashDealProducts,
                menuSpaceBetween: 8,
                contentSpaceBetween: 20,
                memberYn: 'N',
                title: '비츠온 <span class="point-color">반짝특가</span>' }) %>
              </section>
            </div>
          </main>
          <!-- E: vm-main -->

          <%- include(`${_src}/views/layout-mo/footer/index.ejs`, { showFooter: true }) %>
        </div>
        <!-- E: vm-content-wrap -->

        <!-- S: vm-bottom-group -->
        <!-- prettier-ignore -->
        <%- include(`${_src}/views/layout-mo/bottom-bar/index.ejs`, { 
          type: 'tab-bar', currentTab: 'home' 
        }) %>
        <!-- E: vm-bottom-group -->

        <!-- S: 팝업 영역 -->
        <!-- E: 팝업 영역 -->
      </div>
      <!-- E: vm-wrap -->
    </section>
    <!-- E: vm-wrapper -->

    <%- include(`${_src}/views/layout/footer.links.ejs`) %>
  </body>
</html>
