<% const _src = srcPath; const _public = publicPath; %>
<!-- prettier-ignore -->

<%
  const _alarmSettings = [
    { name: 'ckb-sms', value: 'sms', label: '문자 수신', checked: true },
    { name: 'ckb-email', value: 'email', label: '이메일 수신' },
    { name: 'ckb-push', value: 'push', label: '앱 푸시 수신' }
  ];
%>

<!DOCTYPE html>
<html lang="ko" class="vm-scope">
  <%- include(`${_src}/views/layout-mo/header/head.ejs`, {meta_title: '마이페이지'}) %>
  <body class="vm-scope">
    <!-- S: Skip Navigation -->
    <a href="#skipNav" class="skip-nav">본문 바로가기</a>
    <!-- E: Skip Navigation -->

    <!-- S: vm-wrapper -->
    <section class="vm-wrapper">
      <!-- S: vm-wrap -->
      <div class="vm-wrap wrap-my-alarm">
        <!-- S: vm-content-wrap -->
        <div class="vm-content-wrap">
          <!-- prettier-ignore -->
          <%- include(`${_src}/views/layout-mo/header/index.ejs`, { 
            type: 'nav-bar', title: '알림 설정' 
          }) %>

          <!-- S: vm-main -->
          <main id="skipNav" class="vm-main">
            <div class="vm-main-content main-content-my-alarm">
              <section class="vm-mypage-alarm alarm-setting">
                <h2 class="sr-only">알림 설정</h2>

                <div class="alarm-setting" data-checkbox-scope>
                  <div class="alarm-setting-head">
                    <div class="alarm-setting-item">
                      <p class="alarm-setting-label">전체 알림 동의</p>
                      <!-- prettier-ignore -->
                      <%- include(`${_src}/views/components/form/checkbox-toggle.ejs`, {
                        name: 'ckb-setting-all',
                        value: '전체 알림',
                        checkboxType: 'all',
                        label: '전체 알림 동의'
                      }) %>
                    </div>
                  </div>
                  <div class="alarm-setting-body">
                    <% _alarmSettings.forEach(function(item) { %>
                    <div class="alarm-setting-item">
                      <p class="alarm-setting-label"><%= item.label %></p>
                      <!-- prettier-ignore -->
                      <%- include(`${_src}/views/components/form/checkbox-toggle.ejs`, { 
                        name: item.name, 
                        value: item.value, 
                        checkboxType: 'item', 
                        label: item.label,
                        checked: item.checked || false
                      }) %>
                    </div>
                    <% }); %>
                  </div>
                </div>
              </section>
            </div>
          </main>
          <!-- E: vm-main -->

          <%- include(`${_src}/views/layout-mo/footer/index.ejs`) %>
        </div>
        <!-- E: vm-content-wrap -->

        <!-- S: vm-bottom-group -->
        <!-- prettier-ignore -->
        <%- include(`${_src}/views/layout-mo/bottom-bar/index.ejs`, { 
          type: 'tab-bar', currentTab: 'mypage' 
        }) %>
        <!-- E: vm-bottom-group -->

        <!-- S: 팝업 영역 -->
        <!-- E: 팝업 영역 -->
      </div>
      <!-- E: vm-wrap -->
    </section>
    <!-- E: vm-wrapper -->

    <%- include(`${_src}/views/layout/footer.links.ejs`) %>

    <!-- [REMOVE] 퍼블 확인용 임시 코드 - 개발 적용 시 제거 -->
    <script>
      (function () {
        var params = new URLSearchParams(window.location.search);

        // ?empty : 알림 없음 상태 전환
        if (params.get('type') === 'empty') {
          var list = document.querySelector('.alarm-message-list');
          var empty = document.querySelector('.vm-mypage-alarm-empty');
          if (list) list.style.display = 'none';
          if (empty) empty.style.display = '';
        }
      })();
    </script>
  </body>
</html>
