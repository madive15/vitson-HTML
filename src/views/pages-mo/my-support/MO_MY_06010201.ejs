<% const _src = srcPath; const _public = publicPath; %>
<!-- prettier-ignore -->

<!DOCTYPE html>
<html lang="ko" class="vm-scope">
  <%- include(`${_src}/views/layout-mo/header/head.ejs`, {meta_title: '공지사항-상세'}) %>
  <body class="vm-scope">
    <!-- S: Skip Navigation -->
    <a href="#skipNav" class="skip-nav">본문 바로가기</a>
    <!-- E: Skip Navigation -->

    <!-- S: vm-wrapper -->
    <section class="vm-wrapper">
      <!-- S: vm-wrap -->
      <div class="vm-wrap wrap-my-inquiry">
        <!-- S: vm-content-wrap -->
        <div class="vm-content-wrap">
          <!-- prettier-ignore -->
          <%- include(`${_src}/views/layout-mo/header/index.ejs`, { 
            type: 'nav-bar', title: '고객지원센터' 
          }) %>

          <!-- S: vm-main -->
          <main id="skipNav" class="vm-main">
            <div class="vm-main-content main-content-my-inquiry">
              <div class="vm-mypage-inquiry inquiry-detail">
                <div class="vm-mypage-inquiry-detail">
                  <div class="inquiry-detail-notice">
                    <div class="detail-notice-head">
                      <div class="detail-notice-meta">
                        <!-- 
                          [D] 
                            - (고정) 공지.    =>  text: '공지', variant: 'green', iconName: 'notice'
                            - (고정) 가격변동  =>  text: '가격변동', variant: 'red', iconName: 'notice'
                            - 공지           =>  text: '공지', variant: 'green',
                            - 가격변동        =>  text: '가격변동', variant: 'red',
                        -->

                        <%- include(`${_src}/views/components/label/general-label.ejs`, { text: '공지', variant:
                        'green', iconName: 'notice' }) %>
                        <span class="text-date">2027-01-01</span>
                      </div>
                      <h3 class="detail-notice-title">설연휴 배송 휴무 안내</h3>
                    </div>
                    <div class="detail-notice-body">
                      <div class="detail-notice-content">
                        안녕하세요. 비츠온엠알오입니다.<br />
                        저희 쇼핑몰을 이용해 주시는 고객님들께 감사드립니다.<br />
                        배송 관련하여 안내해 드립니다.<br />
                        <br />
                        설 연휴로 인한 택배사 휴무로 배송이 지연될 수 있습니다.<br />
                        1월 28일 이후 순차적으로 배송 될 예정이며, 주문하신 상품은 입금 확인 후 순차 배송됩니다.<br />
                        이점 유의하시어 주문에 참고 부탁드립니다.<br />
                        <br />
                        게시글 내용이 들어가는 영역입니다.
                      </div>
                      <div class="detail-notice-info">
                        <!-- 첨부파일 -->
                        <!-- prettier-ignore -->
                        <%- include(`${_src}/views/components-mo/form/post-attachment.ejs`, { 
                          fileNames: ['01호 인터넷판매불가 안내문.pdf', '첨부파일.jpg', '첨부파일 예시.jpg', '배송 관련 안내문.pdf']
                        }) %>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </main>
          <!-- E: vm-main -->

          <%- include(`${_src}/views/layout-mo/footer/index.ejs`) %>
        </div>
        <!-- E: vm-content-wrap -->

        <!-- S: vm-bottom-group -->
        <!-- prettier-ignore -->
        <%- include(`${_src}/views/layout-mo/bottom-bar/index.ejs`, { 
          type: 'tab-bar', currentTab: 'mypage' 
        }) %>
        <!-- E: vm-bottom-group -->

        <!-- S: 팝업 영역 -->
        <!-- E: 팝업 영역 -->
      </div>
      <!-- E: vm-wrap -->
    </section>
    <!-- E: vm-wrapper -->

    <%- include(`${_src}/views/layout/footer.links.ejs`) %>
  </body>
</html>
