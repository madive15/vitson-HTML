<% const _src = srcPath; const _public = publicPath; %>
<!-- prettier-ignore -->
<%
   // 퍼블 확인용 mock 데이터
  var faqData = require(`${_src}/../public/resources/mock/faq.json`);

  // faqGbCd → 탭 id 매핑
  var gbCdToTabId = {
    '1': 'member',
    '2': 'product',
    '3': 'order',
    '4': 'payment',
    '5': 'delivery'
  };

  // 카테고리 라벨 매핑 (탭 메뉴 + 패널 라벨 공용)
  var categoryLabelMap = {
    all: '전체',
    member: '회원',
    product: '상품',
    order: '주문',
    payment: '결제',
    delivery: '배송/반품/교환'
  };

  // 탭 메뉴 생성
  var faqTabs = Object.keys(categoryLabelMap).map(function(key) {
    return { id: key, label: categoryLabelMap[key] };
  });

  // 업데이트 날짜 → 생성 날짜 기준 내림차순
  faqData.sort(function(a, b) {
    var dateA = a.udatetime || a.rdatetime || 0;
    var dateB = b.udatetime || b.rdatetime || 0;
    return dateB - dateA;
  });
%>

<!DOCTYPE html>
<html lang="ko" class="vm-scope">
  <%- include(`${_src}/views/layout-mo/header/head.ejs`, {meta_title: 'FAQ'}) %>
  <body class="vm-scope">
    <!-- S: Skip Navigation -->
    <a href="#skipNav" class="skip-nav">본문 바로가기</a>
    <!-- E: Skip Navigation -->

    <!-- S: vm-wrapper -->
    <section class="vm-wrapper">
      <!-- S: vm-wrap -->
      <div class="vm-wrap wrap-my-support">
        <!-- S: vm-content-wrap -->
        <div class="vm-content-wrap">
          <!-- prettier-ignore -->
          <%- include(`${_src}/views/layout-mo/header/index.ejs`, { 
            type: 'nav-bar', title: '고객지원센터' 
          }) %>

          <!-- S: vm-main -->
          <main id="skipNav" class="vm-main">
            <div class="vm-main-content main-content-my-support">
              <div class="vm-mypage-support">
                <!-- prettier-ignore -->
                <%- include(`${_src}/views/components-mo/mypage/support-nav.ejs`, { 
                  currentTab: 1 
                }) %>
                <div class="vm-mypage-support-panel panel-pd-zero">
                  <div class="vm-mypage-support-tab tab-faq">
                    <div class="support-tab-filter">
                      <!-- prettier-ignore -->
                      <%- include(`${_src}/views/components/form/input-search.ejs`, {
                        idPrefix: 'archive-search',
                        action: '/archive-search',
                        name: 'archive-search',
                        placeholder: '찾으시는 질문을 검색해보세요',
                        addClassName: 'size-xl theme-gray',
                        hasClear: true
                      }) %>
                    </div>

                    <!-- [D] FAQ 목록 -->
                    <div class="support-tab-section" data-tab-scope>
                      <!-- [D] 활성 탭의 button에 is-active 클래스 추가 -->
                      <ul class="support-tab" role="tablist">
                        <% faqTabs.forEach(function(tab, index) { %>
                        <li class="support-tab-item" role="presentation">
                          <button
                            type="button"
                            class="support-tab-btn<%= index === 0 ? ' is-active' : '' %>"
                            role="tab"
                            aria-selected="<%= index === 0 ? 'true' : 'false' %>"
                            aria-controls="support-tab-panel-<%= tab.id %>"
                            data-tab-btn
                            data-tab-target="support-tab-<%= tab.id %>"
                          >
                            <%= tab.label %>
                          </button>
                        </li>
                        <% }) %>
                      </ul>

                      <!-- [D] 활성 패널에 is-active 클래스 추가, 비활성 패널은 hidden 처리 -->
                      <% faqTabs.forEach(function(tab, index) { %>
                      <div
                        class="support-tab-panel"
                        data-tab-panel="support-tab-<%= tab.id %>"
                        role="tabpanel"
                        <%= index !== 0 ? 'hidden' : '' %>
                      >
                        <%
                          var filtered = tab.id === 'all'
                            ? faqData
                            : faqData.filter(function(item) { return gbCdToTabId[item.faqGbCd] === tab.id; });
                        %>
                        <!-- [D] 열린 항목의 data-toggle-box에 is-open 클래스 추가 -->
                        <div class="support-tab-accordion-list" data-toggle-scope data-toggle-group="true">
                          <% filtered.forEach(function(item, idx) { %>
                          <div class="support-tab-accordion-item">
                            <button
                              type="button"
                              class="support-tab-accordion-trigger"
                              aria-expanded="false"
                              data-toggle-btn
                              data-toggle-target="support-tab-<%= tab.id %>-<%= idx %>"
                            >
                              <!-- prettier-ignore -->
                              <%- include(`${_src}/views/components/label/general-label.ejs`, { 
                                text: categoryLabelMap[gbCdToTabId[item.faqGbCd]], 
                                variant:'sunken'
                              }) %>
                              <span class="support-tab-accordion-title">
                                <span class="text"><%= item.title %></span>
                                <span class="icon"><%- include(`${_src}/views/components/icon.ejs`, { iconName: 'arrow-down' }) %></span>
                              </span>
                            </button>
                            <div class="support-tab-accordion-content" data-toggle-box="support-tab-<%= tab.id %>-<%= idx %>">
                              <div class="support-tab-accordion-answer"><%- item.contents %></div>
                            </div>
                          </div>
                          <% }) %>
                        </div>
                      </div>
                      <% }) %>
                    </div>

                    <!-- [D] No Data: FAQ 없음 -->
                    <div class="vm-mypage-inquiry-empty empty-no-data" style="display: none">
                      <!-- prettier-ignore -->
                      <%- include(`${_src}/views/components/empty-state.ejs`, {
                        iconName: 'document-paper',
                        title: '등록된 FAQ가 없습니다',
                      }) %>
                    </div>

                    <!-- [D] No Data: 검색 결과 없음 -->
                    <div class="vm-mypage-inquiry-empty empty-no-search" style="display: none">
                      <!-- prettier-ignore -->
                      <%- include(`${_src}/views/components/empty-state.ejs`, {
                        iconName: 'document-paper',
                        title: '검색 결과가 없습니다',
                      }) %>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </main>
          <!-- E: vm-main -->

          <%- include(`${_src}/views/layout-mo/footer/index.ejs`) %>
        </div>
        <!-- E: vm-content-wrap -->

        <!-- S: vm-bottom-group -->
        <!-- prettier-ignore -->
        <%- include(`${_src}/views/layout-mo/bottom-bar/index.ejs`, { 
          type: 'tab-bar', currentTab: 'mypage' 
        }) %>
        <!-- E: vm-bottom-group -->

        <!-- S: 팝업 영역 -->
        <!-- E: 팝업 영역 -->
      </div>
      <!-- E: vm-wrap -->
    </section>
    <!-- E: vm-wrapper -->

    <%- include(`${_src}/views/layout/footer.links.ejs`) %>

    <!-- S: [REMOVE] 확인용 임시 코드 - 개발 적용 시 제거 -->
    <script>
      $(function () {
        var type = new URLSearchParams(location.search).get('type');

        if (type === 'empty') {
          $('.support-tab-section').hide();
          $('.empty-no-data').show();
        } else if (type === 'search-empty') {
          $('#archive-search-searchKeyword').val('접착테이프').trigger('input');
          $('[data-search-clear]').removeAttr('hidden');
          $('.support-tab-section').hide();
          $('.empty-no-search').show();
        }
      });
    </script>
    <!-- E: [REMOVE] 확인용 임시 코드 - 개발 적용 시 제거 -->
  </body>
</html>
