<% const _src = srcPath; const _public = publicPath; %>
<!-- prettier-ignore -->

<!DOCTYPE html>
<html lang="ko" class="vm-scope">
  <%- include(`${_src}/views/layout-mo/header/head.ejs`, {meta_title: '시스템 점검'}) %>
  <body class="vm-scope">
    <!-- S: Skip Navigation -->
    <a href="#skipNav" class="skip-nav">본문 바로가기</a>
    <!-- E: Skip Navigation -->

    <!-- S: vm-wrapper -->
    <section class="vm-wrapper">
      <!-- S: vm-wrap -->
      <div class="vm-wrap wrap-system">
        <!-- S: vm-content-wrap -->
        <div class="vm-content-wrap">
          <%# [D] 오류페이지 - header 없음 %>
          <!-- prettier-ignore -->
          <%# < %- include(`${_src}/views/layout-mo/header/index.ejs`, { 
            type: 'mypage-bar', 
            alarm: true,
          }) % > %>

          <!-- S: vm-main -->
          <main id="skipNav" class="vm-main">
            <div class="vm-main-content main-content-system">
              <section class="vm-system-section">
                <!-- prettier-ignore -->
                <%- include(`${_src}/views/components/empty-state.ejs`, { 
                  iconName: 'info', 
                  title: '서비스 점검 안내', 
                  desc: '더 나은 서비스를 제공하기 위해 시스템 점검을 하고 있습니다\n점검 시간 동안에는 서비스 이용이 일시적으로 제한되오니 양해 부탁드립니다', 
                  }) %>

                <div class="vm-system-notice">
                  <p class="text">점검 일시</p>
                  <p class="text"><strong>2025-09-11 13:00 ~ 점검 완료 시 까지</strong></p>
                </div>
              </section>
            </div>
          </main>
          <!-- E: vm-main -->

          <%- include(`${_src}/views/layout-mo/footer/index.ejs`) %>
        </div>
        <!-- E: vm-content-wrap -->

        <!-- S: vm-bottom-group -->
        <!-- prettier-ignore -->
        <%- include(`${_src}/views/layout-mo/bottom-bar/index.ejs`, { 
          type: 'tab-bar', currentTab: '' 
        }) %>
        <!-- E: vm-bottom-group -->

        <!-- S: 팝업 영역 -->
        <!-- E: 팝업 영역 -->
      </div>
      <!-- E: vm-wrap -->
    </section>
    <!-- E: vm-wrapper -->

    <%- include(`${_src}/views/layout/footer.links.ejs`) %>

    <!-- [REMOVE] 퍼블 확인용 임시 코드 - 개발 적용 시 제거 -->
    <script>
      (function () {
        var params = new URLSearchParams(window.location.search);

        // ?type02 : 프로필 타입2 전환
        if (params.has('type02')) {
          var type01 = document.querySelector('.profile-type01');
          var type02 = document.querySelector('.profile-type02');
          if (type01) type01.classList.add('is-hidden');
          if (type02) type02.classList.remove('is-hidden');
        }
      })();
    </script>
  </body>
</html>
