<% const _src = srcPath; const _public = publicPath; %>

<!DOCTYPE html>
<!-- 
  [D] vits-scope: 스크롤바 커스텀 범위 제한(운영 전역 scrollbar 충돌 방지)
    - 문서 스크롤 주체가 html/body로 달라질 수 있어 둘 다 클래스 적용 
  -->
<html lang="ko" class="vits-scope">
  <%- include(`${_src}/views/layout/head.ejs`, {meta_title: '가이드 - 페이지네이션'}) %>
  <!-- [D] vits-scope 적용(상단 주석 참고) || 가이드 페이지 식별: data-guide="true" -->
  <body class="vits-scope" data-guide="true">
    <main>
      <!-- S: vits-guide-wrapper -->
      <section class="vits-guide-wrapper" aria-labelledby="guide-icons-title">
        <h2 class="vits-guide-title" id="guide-icons-title">Pagination</h2>

        <h3 class="vits-guide-subtitle">kendo</h3>
        <div class="vits-guide-wrap">
          <ul class="vits-guide-list full">
            <li>
              <!-- [D] vits-kendo-pagination 랩핑 -->
              <div class="vits-kendo-pagination">
                <!-- [D] 자주구매 - https://new-mro.isvmtest.com/mro/mypage/histProList.do -->
                <div
                  id="histProPager"
                  style="display: flex; justify-content: center"
                  data-role="pager"
                  class="k-pager k-pager-md"
                >
                  <div class="k-pager-numbers-wrap">
                    <button
                      role="button"
                      title="첫 페이지"
                      aria-label="첫 페이지"
                      class="k-pager-nav k-button k-button-flat k-button-flat-base k-icon-button k-pager-first k-button-md k-disabled"
                      data-page="1"
                      tabindex="-1"
                      aria-disabled="true"
                    >
                      <span class="k-button-icon k-icon k-svg-icon k-svg-i-caret-alt-to-left" aria-hidden="true"
                        ><svg viewBox="0 0 512 512" focusable="false" xmlns="http://www.w3.org/2000/svg">
                          <path d="M352 384 160 256l192-128zM128 128v256h32V128z"></path></svg
                      ></span></button
                    ><button
                      role="button"
                      title="이전 페이지"
                      aria-label="이전 페이지"
                      class="k-pager-nav k-button k-button-flat k-button-flat-base k-icon-button k-button-md k-disabled"
                      data-page="1"
                      tabindex="-1"
                      aria-disabled="true"
                    >
                      <span class="k-button-icon k-icon k-svg-icon k-svg-i-caret-alt-left" aria-hidden="true"
                        ><svg viewBox="0 0 512 512" focusable="false" xmlns="http://www.w3.org/2000/svg">
                          <path d="m160 256 192-128v256z"></path></svg
                      ></span></button
                    ><select
                      aria-label="Page select"
                      class="k-dropdown k-picker k-picker-solid k-dropdown-list k-rounded-md k-picker-md"
                      style="display: none"
                    >
                      <option value="1" selected="selected">1</option>
                    </select>
                    <div class="k-pager-numbers">
                      <button
                        role="button"
                        aria-current="page"
                        tabindex="-1"
                        aria-label="Page 1"
                        class="k-button k-button-md k-button-flat k-button-flat-primary k-selected"
                      >
                        <span class="k-button-text">1</span>
                      </button>
                    </div>
                    <button
                      role="button"
                      title="다음 페이지"
                      aria-label="다음 페이지"
                      class="k-pager-nav k-button k-button-flat k-button-flat-base k-icon-button k-button-md k-disabled"
                      data-page="1"
                      tabindex="-1"
                      aria-disabled="true"
                    >
                      <span class="k-button-icon k-icon k-svg-icon k-svg-i-caret-alt-right" aria-hidden="true"
                        ><svg viewBox="0 0 512 512" focusable="false" xmlns="http://www.w3.org/2000/svg">
                          <path d="M352 256 160 384V128z"></path></svg
                      ></span></button
                    ><button
                      role="button"
                      title="마지막 페이지"
                      aria-label="마지막 페이지"
                      class="k-pager-nav k-button k-button-flat k-button-flat-base k-icon-button k-pager-last k-button-md k-disabled"
                      data-page="1"
                      tabindex="-1"
                      aria-disabled="true"
                    >
                      <span class="k-button-icon k-icon k-svg-icon k-svg-i-caret-alt-to-right" aria-hidden="true"
                        ><svg viewBox="0 0 512 512" focusable="false" xmlns="http://www.w3.org/2000/svg">
                          <path d="m128 128 192 128-192 128zm224 256V128h-32v256z"></path></svg
                      ></span>
                    </button>
                  </div>
                  <span class="k-pager-sizes"
                    ><span
                      title=""
                      class="k-picker k-dropdownlist k-picker-solid k-picker-md k-rounded-md k-focus"
                      unselectable="on"
                      role="combobox"
                      aria-expanded="false"
                      tabindex="0"
                      aria-controls="b1d84c0f-0ad8-44b3-b36a-7b6f6fb45917_listbox"
                      aria-label="Page sizes drop down"
                      aria-disabled="false"
                      aria-readonly="false"
                      aria-busy="false"
                      aria-describedby="e133ec70-d021-4fe5-8f97-fdb431f6df24"
                      style=""
                      ><span id="e133ec70-d021-4fe5-8f97-fdb431f6df24" unselectable="on" class="k-input-inner"
                        ><span class="k-input-value-text">20</span></span
                      ><span
                        role="button"
                        class="k-input-button k-button k-button-md k-button-solid k-button-solid-base k-icon-button"
                        aria-label="select"
                        type="button"
                        ><span class="k-icon k-svg-icon k-svg-i-caret-alt-down k-button-icon" aria-hidden="true"
                          ><svg viewBox="0 0 512 512" focusable="false" xmlns="http://www.w3.org/2000/svg">
                            <path d="M256 352 128 160h256z"></path></svg></span></span
                      ><select aria-label="Page sizes drop down" data-role="dropdownlist" style="display: none">
                        <option value="10">10</option>
                        <option value="20" selected="selected">20</option>
                        <option value="30">30</option>
                      </select></span
                    ><span>개 씩 보기</span></span
                  >
                </div>
              </div>
            </li>
            <li>
              <div style="position: relative; width: 100%; padding: 10px; height: 106px">
                <!-- style="
                    height: auto;
                    top: 2825.62px;
                    z-index: 10002;
                    left: 1353px;
                    position: absolute;
                    overflow: hidden;
                  " -->
                <div
                  class="k-animation-container vits-kendo-pagination-popup"
                  role="region"
                  aria-hidden="true"
                  aria-label="Page sizes drop down"
                >
                  <!-- style="height: 86px; transform: translateY(-86px); width: 70px; display: none" -->
                  <div class="k-child-animation-container">
                    <div
                      class="k-list-container k-popup k-dropdownlist-popup"
                      data-role="popup"
                      aria-hidden="true"
                      style="
                        font-size: 14px;
                        font-family: 'Noto Sans KR', 'malgun gothic', dotum, gulim, arial, 'apple gothic', sans-serif;
                        font-stretch: 100%;
                        font-style: normal;
                        font-weight: 400;
                        line-height: 20px;
                        width: 70px;
                        min-width: 70px;
                        white-space: normal;
                        height: 114px;
                      "
                    >
                      <div class="k-list k-list-md" id="b1d84c0f-0ad8-44b3-b36a-7b6f6fb45917-list" style="height: auto">
                        <div class="k-list-group-sticky-header" style="display: none"></div>
                        <div class="k-list-content k-list-scroller" unselectable="on">
                          <ul
                            unselectable="on"
                            tabindex="-1"
                            aria-hidden="true"
                            id="b1d84c0f-0ad8-44b3-b36a-7b6f6fb45917_listbox"
                            aria-live="off"
                            data-role="staticlist"
                            role="listbox"
                            aria-label="Page sizes drop down"
                            class="k-list-ul"
                          >
                            <li
                              tabindex="-1"
                              role="option"
                              unselectable="on"
                              class="k-list-item"
                              aria-selected="false"
                              data-offset-index="0"
                            >
                              <span class="k-list-item-text">10</span>
                            </li>
                            <li
                              tabindex="-1"
                              role="option"
                              unselectable="on"
                              class="k-list-item k-selected k-focus"
                              aria-selected="true"
                              data-offset-index="1"
                              id="fcdc3c5f-aa1f-4821-b02d-630a89996c87"
                            >
                              <span class="k-list-item-text">20</span>
                            </li>
                            <li
                              tabindex="-1"
                              role="option"
                              unselectable="on"
                              class="k-list-item"
                              aria-selected="false"
                              data-offset-index="2"
                            >
                              <span class="k-list-item-text">30</span>
                            </li>
                          </ul>
                        </div>
                        <div class="k-no-data" style="display: none">No data found.</div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </li>
            <li>
              <!-- [D] vits-kendo-pagination 랩핑 -->
              <div class="vits-kendo-pagination">
                <!-- [D] 주문/배송조회 - https://new-mro.isvmtest.com/mro/shop/orderList.do -->
                <div id="orderPager" data-role="pager" class="k-pager k-pager-md">
                  <div class="k-pager-numbers-wrap">
                    <button
                      role="button"
                      title="첫 페이지"
                      aria-label="첫 페이지"
                      class="k-pager-nav k-button k-button-flat k-button-flat-base k-icon-button k-pager-first k-button-md k-disabled"
                      data-page="1"
                      tabindex="-1"
                      aria-disabled="true"
                    >
                      <span class="k-button-icon k-icon k-svg-icon k-svg-i-caret-alt-to-left" aria-hidden="true"
                        ><svg viewBox="0 0 512 512" focusable="false" xmlns="http://www.w3.org/2000/svg">
                          <path d="M352 384 160 256l192-128zM128 128v256h32V128z"></path></svg
                      ></span></button
                    ><button
                      role="button"
                      title="이전 페이지"
                      aria-label="이전 페이지"
                      class="k-pager-nav k-button k-button-flat k-button-flat-base k-icon-button k-button-md k-disabled"
                      data-page="1"
                      tabindex="-1"
                      aria-disabled="true"
                    >
                      <span class="k-button-icon k-icon k-svg-icon k-svg-i-caret-alt-left" aria-hidden="true"
                        ><svg viewBox="0 0 512 512" focusable="false" xmlns="http://www.w3.org/2000/svg">
                          <path d="m160 256 192-128v256z"></path></svg
                      ></span></button
                    ><select
                      aria-label="Page select"
                      class="k-dropdown k-picker k-picker-solid k-dropdown-list k-rounded-md k-picker-md"
                      style="display: none"
                    >
                      <option value="1" selected="selected">1</option>
                      <option value="2">2</option>
                      <option value="3">3</option>
                      <option value="4">4</option>
                    </select>
                    <div class="k-pager-numbers">
                      <button
                        role="button"
                        aria-current="page"
                        tabindex="-1"
                        aria-label="Page 1"
                        class="k-button k-button-md k-button-flat k-button-flat-primary k-selected"
                      >
                        <span class="k-button-text">1</span></button
                      ><button
                        class="k-button k-button-md k-button-flat k-button-flat-primary"
                        tabindex="-1"
                        href="#"
                        data-page="2"
                        title="Page 2"
                      >
                        <span class="k-button-text">2</span></button
                      ><button
                        class="k-button k-button-md k-button-flat k-button-flat-primary"
                        tabindex="-1"
                        href="#"
                        data-page="3"
                        title="Page 3"
                      >
                        <span class="k-button-text">3</span></button
                      ><button
                        class="k-button k-button-md k-button-flat k-button-flat-primary"
                        tabindex="-1"
                        href="#"
                        data-page="4"
                        title="Page 4"
                      >
                        <span class="k-button-text">4</span>
                      </button>
                    </div>
                    <button
                      role="button"
                      title="다음 페이지"
                      aria-label="다음 페이지"
                      class="k-pager-nav k-button k-button-flat k-button-flat-base k-icon-button k-button-md"
                      data-page="2"
                      tabindex="0"
                      aria-disabled="false"
                    >
                      <span class="k-button-icon k-icon k-svg-icon k-svg-i-caret-alt-right" aria-hidden="true"
                        ><svg viewBox="0 0 512 512" focusable="false" xmlns="http://www.w3.org/2000/svg">
                          <path d="M352 256 160 384V128z"></path></svg
                      ></span></button
                    ><button
                      role="button"
                      title="마지막 페이지"
                      aria-label="마지막 페이지"
                      class="k-pager-nav k-button k-button-flat k-button-flat-base k-icon-button k-pager-last k-button-md"
                      data-page="4"
                      tabindex="0"
                      aria-disabled="false"
                    >
                      <span class="k-button-icon k-icon k-svg-icon k-svg-i-caret-alt-to-right" aria-hidden="true"
                        ><svg viewBox="0 0 512 512" focusable="false" xmlns="http://www.w3.org/2000/svg">
                          <path d="m128 128 192 128-192 128zm224 256V128h-32v256z"></path></svg
                      ></span>
                    </button>
                  </div>
                </div>
              </div>
            </li>
          </ul>
        </div>

        <h3 class="vits-guide-subtitle">타입 default</h3>

        <div class="vits-guide-code">
          <code>
            <pre>
&lt;%- include(`${_src}/views/components/pagination.ejs`, { type: 'default', current: 1, isPrevDisabled: true }) %&gt;
            </pre>
          </code>
        </div>

        <div class="vits-guide-wrap">
          <ul class="vits-guide-list full">
            <li>
              <h3>Default</h3>
              <!-- prettier-ignore -->
              <%- include(`${_src}/views/components/pagination.ejs`, { type: 'default', current: 1, isPrevDisabled: true }) %>
            </li>
          </ul>
        </div>

        <h3 class="vits-guide-subtitle">타입 Expanded</h3>

        <div class="vits-guide-code">
          <code>
            <pre>
&lt;%- include(`${_src}/views/components/pagination.ejs`, { type: 'expanded', current: 1 }) %&gt;
            </pre>
          </code>
        </div>

        <div class="vits-guide-wrap">
          <ul class="vits-guide-list full">
            <li><%- include(`${_src}/views/components/pagination.ejs`, { type: 'expanded', current: 1 }) %></li>
          </ul>
        </div>

        <h3 class="vits-guide-subtitle">타입 Truncated</h3>

        <div class="vits-guide-code">
          <code>
            <pre>
&lt;%- include(`${_src}/views/components/pagination.ejs`, { type: 'truncated', current: 25 }) %&gt;
            </pre>
          </code>
        </div>

        <div class="vits-guide-wrap">
          <ul class="vits-guide-list full">
            <li><%- include(`${_src}/views/components/pagination.ejs`, { type: 'truncated', current: 25 }) %></li>
          </ul>
        </div>
      </section>
      <!-- E: vits-guide-wrapper -->
    </main>

    <%- include(`${_src}/views/layout/footer.links.ejs`) %>
  </body>
</html>
