<% const _src = srcPath; const _public = publicPath; %>
<!-- prettier-ignore -->
<% const _base = srcPath.includes('vitson-HTML') ? '/vitson-HTML' : ''; %>
<%
  const catPath = (typeof categoryPath !== 'undefined' && categoryPath) ? categoryPath : {};
%>

<!-- [26-03-12] data-tree-url: 퍼블 목업용 경로, 실서버에서는 비우거나 속성 제거 -->
<div
  class="vm-category-sheet"
  data-category-sheet
  data-tree-url="<%- _base %>/public/resources/mock/category.json"
  data-depth1="<%= catPath.depth1Id || '' %>"
  data-depth2="<%= catPath.depth2Id || '' %>"
  data-depth3="<%= catPath.depth3Id || '' %>"
>
  <div class="sheet-body">
    <div class="depth1-panel" data-depth1-panel>
      <ul class="depth1-list" data-depth1-list role="listbox" aria-label="대분류"></ul>
    </div>
    <div class="depth-sub-panel" data-sub-panel>
      <ul class="depth-sub-list" data-sub-list role="group" aria-label="중/소분류"></ul>
    </div>
  </div>
</div>

<%#
